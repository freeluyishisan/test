# App
APP_ENV=development
APP_TIMEZONE=Asia/Hong_Kong
LOG_LEVEL=INFO

# Runtime
PAPER_TRADING=true
ENABLE_LIVE_TRADING=false

# Risk
BANKROLL_USDC=1000
MIN_EDGE_TO_TRADE=0.08
STRONG_EDGE=0.12
MAX_TRADE_SIZE_USDC=20
DAILY_LOSS_LIMIT_USDC=100
MAX_DATA_STALENESS_SECONDS=180

# Polymarket
POLYMARKET_ENABLED=false
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Database, later
DATABASE_URL=sqlite:///./data/east8_weather_trader.db
REDIS_URL=redis://localhost:6379/0

# HKO sources
HKO_TEXTONLY_URL=https://www.hko.gov.hk/textonly/v2/forecast/text_readings_e.htm
HKO_CSV_URL=https://www.hko.gov.hk/wxinfo/awsgis/hko.csv
